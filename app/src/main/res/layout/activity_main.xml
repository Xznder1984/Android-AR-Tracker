<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_black"
    android:keepScreenOn="true">

    <!-- Camera preview (full bleed). -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:implementationMode="performance"
        app:scaleType="fillCenter" />

    <!-- Image overlay surface (drag/scale/rotate happens here). -->
    <com.artracer.app.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Optional grid (drawn above overlay). -->
    <com.artracer.app.GridOverlayView
        android:id="@+id/gridOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Empty-state hint (shows until an image is loaded). -->
    <TextView
        android:id="@+id/hintLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:background="@drawable/bg_hint"
        android:textColor="@color/fg_primary"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/hint_no_image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top-left compact action chips (lock + grid + flip + reset + fullscreen). -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start|center_vertical"
        android:background="@drawable/bg_panel"
        android:padding="6dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLock"
            style="@style/ChipButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_unlock"
            app:iconTint="@color/fg_primary"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            android:layout_marginEnd="6dp"
            android:text="@string/action_unlock"
            android:contentDescription="@string/action_unlock" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrid"
            style="@style/ChipButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_grid"
            app:iconTint="@color/fg_primary"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            android:layout_marginEnd="6dp"
            android:text="@string/action_grid"
            android:contentDescription="@string/action_grid" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFlip"
            style="@style/ChipButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_flip"
            app:iconTint="@color/fg_primary"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            android:layout_marginEnd="6dp"
            android:text="@string/action_flip"
            android:contentDescription="@string/action_flip" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            style="@style/ChipButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_reset"
            app:iconTint="@color/fg_primary"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            android:layout_marginEnd="6dp"
            android:text="@string/action_reset"
            android:contentDescription="@string/action_reset" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFullscreen"
            style="@style/ChipButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_fullscreen"
            app:iconTint="@color/fg_primary"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:minWidth="40dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:contentDescription="@string/action_fullscreen" />
    </LinearLayout>

    <!-- Bottom panel (opacity slider + pick + capture). -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_panel"
        android:padding="14dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_opacity"
                android:contentDescription="@string/opacity_label" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/opacity_label"
                android:textColor="@color/fg_muted"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04" />

            <TextView
                android:id="@+id/opacityValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="60%"
                android:textColor="@color/fg_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/opacitySlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:value="60"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="1"
            app:thumbColor="@color/accent"
            app:trackColorActive="@color/accent"
            app:trackColorInactive="@color/divider"
            app:haloColor="@color/accent_dim" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickImage"
                style="@style/ChipButton.Primary"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_image"
                app:iconTint="@color/fg_on_accent"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                android:layout_marginEnd="8dp"
                android:text="@string/action_pick_image" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCapture"
                style="@style/ChipButton.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_shutter"
                app:iconTint="@color/fg_on_accent"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:minWidth="48dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:contentDescription="@string/action_screenshot" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
